prototype-v2/local-config.js
prototype/local-config.js
**/local-config.js

# Generic env files in case we move to a server-side proxy later
.env
.env.*
!.env.example

# =============================================================================
# OS noise
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*~

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp

# =============================================================================
