# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# =============================================================================
# Build / cache outputs (none yet, but harmless to pre-empt)
# =============================================================================
dist/
build/
.cache/

