[
  { "id": "s_001", "item_type": "utterance", "text": "I'm going home now.",                "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["AY", "OW", "M"] },
  { "id": "s_002", "item_type": "utterance", "text": "Can you help me?",                   "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["K", "Y", "HH"] },
  { "id": "s_003", "item_type": "utterance", "text": "What time is it?",                   "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["W", "T", "IH"] },
  { "id": "s_004", "item_type": "utterance", "text": "I don't understand.",                "word_count": 3, "cefr_level": "A1", "difficulty": "easy",   "features": ["reductions", "rhythm"],                           "target_phonemes": ["AY", "AH", "S"] },
  { "id": "s_005", "item_type": "utterance", "text": "Where is the station?",              "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["W", "DH", "SH"] },
  { "id": "s_006", "item_type": "utterance", "text": "How are you today?",                 "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["HH", "AW", "Y"] },
  { "id": "s_007", "item_type": "utterance", "text": "Tell me about it.",                  "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["T", "AH", "B"] },
  { "id": "s_008", "item_type": "utterance", "text": "Could you repeat that?",             "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "rhythm"],             "target_phonemes": ["K", "R", "DH"] },
  { "id": "s_009", "item_type": "utterance", "text": "I'd love to come.",                  "word_count": 4, "cefr_level": "A2", "difficulty": "easy",   "features": ["weak_forms", "rhythm"],                           "target_phonemes": ["L", "T", "K"] },
  { "id": "s_010", "item_type": "utterance", "text": "Thanks for your help.",              "word_count": 4, "cefr_level": "A1", "difficulty": "medium", "features": ["weak_forms", "rhythm"],                           "target_phonemes": ["TH", "F", "HH"] },
  { "id": "s_011", "item_type": "utterance", "text": "Let me think about it.",             "word_count": 5, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["L", "TH", "B"] },
  { "id": "s_012", "item_type": "utterance", "text": "What do you mean?",                  "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["reductions", "rhythm"],                           "target_phonemes": ["W", "Y", "M"] },
  { "id": "s_013", "item_type": "utterance", "text": "It's getting late.",                 "word_count": 3, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["IH", "G", "L"] },
  { "id": "s_014", "item_type": "utterance", "text": "I'm not sure about that.",           "word_count": 5, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["AY", "SH", "DH"] },
  { "id": "s_015", "item_type": "utterance", "text": "Have a good day.",                   "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["HH", "G", "D"] },
  { "id": "s_016", "item_type": "utterance", "text": "See you tomorrow.",                  "word_count": 3, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["S", "Y", "M"] },
  { "id": "s_017", "item_type": "utterance", "text": "I forgot my keys.",                  "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "rhythm"],                              "target_phonemes": ["F", "M", "K"] },
  { "id": "s_018", "item_type": "utterance", "text": "Nice to meet you.",                  "word_count": 4, "cefr_level": "A1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["N", "T", "Y"] },
  { "id": "s_019", "item_type": "utterance", "text": "Can I have some water?",             "word_count": 5, "cefr_level": "A1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["K", "HH", "W"] },
  { "id": "s_020", "item_type": "utterance", "text": "What's the weather like?",           "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "rhythm"],                           "target_phonemes": ["W", "DH", "L"] },
  { "id": "s_021", "item_type": "utterance", "text": "I'll see you later.",                "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "rhythm"],                              "target_phonemes": ["AY", "S", "L"] },
  { "id": "s_022", "item_type": "utterance", "text": "How much does it cost?",             "word_count": 5, "cefr_level": "A1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["HH", "M", "K"] },
  { "id": "s_023", "item_type": "utterance", "text": "I think you're right.",              "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "rhythm"],                              "target_phonemes": ["TH", "Y", "R"] },
  { "id": "s_024", "item_type": "utterance", "text": "Could I have the bill?",             "word_count": 5, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["K", "HH", "B"] },
  { "id": "s_025", "item_type": "utterance", "text": "Where are you from?",                "word_count": 4, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["W", "R", "F"] },
  { "id": "s_026", "item_type": "utterance", "text": "Just a moment please.",              "word_count": 4, "cefr_level": "A1", "difficulty": "medium", "features": ["weak_forms", "rhythm"],                           "target_phonemes": ["JH", "M", "P"] },
  { "id": "s_027", "item_type": "utterance", "text": "Speak more slowly please.",          "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "rhythm"],                              "target_phonemes": ["S", "M", "L"] },
  { "id": "s_028", "item_type": "utterance", "text": "I really enjoyed it.",               "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "rhythm"],                              "target_phonemes": ["R", "JH", "OY"] },
  { "id": "s_029", "item_type": "utterance", "text": "What did you say?",                  "word_count": 4, "cefr_level": "A1", "difficulty": "medium", "features": ["reductions", "rhythm"],                           "target_phonemes": ["W", "D", "EY"] },
  { "id": "s_030", "item_type": "utterance", "text": "I've been waiting here.",            "word_count": 4, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["V", "B", "W"] },

  { "id": "s_031", "item_type": "sentence", "text": "She asked me to call her later.",                          "word_count": 7, "cefr_level": "A2", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["SH", "K", "L"] },
  { "id": "s_032", "item_type": "sentence", "text": "I need to find my phone again.",                            "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["N", "F", "AY"] },
  { "id": "s_033", "item_type": "sentence", "text": "We should leave before it gets dark.",                      "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["SH", "L", "B"] },
  { "id": "s_034", "item_type": "sentence", "text": "Could you pass me the salt please?",                        "word_count": 7, "cefr_level": "A1", "difficulty": "medium", "features": ["weak_forms", "rhythm"],                                     "target_phonemes": ["K", "P", "S"] },
  { "id": "s_035", "item_type": "sentence", "text": "He's been working there for two years.",                    "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["W", "DH", "Y"] },
  { "id": "s_036", "item_type": "sentence", "text": "I usually go to bed at eleven.",                            "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["Y", "G", "B"] },
  { "id": "s_037", "item_type": "sentence", "text": "They're planning to visit us next week.",                   "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["DH", "V", "W"] },
  { "id": "s_038", "item_type": "sentence", "text": "Don't forget to lock the door.",                            "word_count": 6, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "rhythm"],                                     "target_phonemes": ["F", "L", "D"] },
  { "id": "s_039", "item_type": "sentence", "text": "I think it's going to rain soon.",                          "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "rhythm"],                       "target_phonemes": ["TH", "G", "R"] },
  { "id": "s_040", "item_type": "sentence", "text": "She doesn't drink coffee in the morning.",                  "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["SH", "K", "M"] },
  { "id": "s_041", "item_type": "sentence", "text": "We met at the train station yesterday.",                    "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["M", "T", "Y"] },
  { "id": "s_042", "item_type": "sentence", "text": "The film starts at half past seven.",                       "word_count": 7, "cefr_level": "A1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["DH", "S", "F"] },
  { "id": "s_043", "item_type": "sentence", "text": "I'd like to learn another language.",                       "word_count": 6, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["L", "DH", "NG"] },
  { "id": "s_044", "item_type": "sentence", "text": "He's going to be late again today.",                        "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "rhythm"],                       "target_phonemes": ["G", "L", "T"] },
  { "id": "s_045", "item_type": "sentence", "text": "Can you tell me your name please?",                         "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["K", "T", "N"] },
  { "id": "s_046", "item_type": "sentence", "text": "I haven't seen her since last summer.",                     "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["V", "S", "M"] },
  { "id": "s_047", "item_type": "sentence", "text": "We're meeting them at the restaurant tonight.",             "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["M", "T", "R"] },
  { "id": "s_048", "item_type": "sentence", "text": "She's living in London at the moment.",                     "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["SH", "L", "M"] },
  { "id": "s_049", "item_type": "sentence", "text": "I really enjoyed the book you gave me.",                    "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["R", "JH", "B"] },
  { "id": "s_050", "item_type": "sentence", "text": "Would you mind closing the window please?",                 "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "rhythm"],                       "target_phonemes": ["W", "M", "K"] },
  { "id": "s_051", "item_type": "sentence", "text": "He was reading when I came in.",                            "word_count": 7, "cefr_level": "A2", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["R", "K", "AY"] },
  { "id": "s_052", "item_type": "sentence", "text": "I'd rather stay at home tonight.",                          "word_count": 6, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["DH", "S", "T"] },
  { "id": "s_053", "item_type": "sentence", "text": "We've been waiting here for an hour.",                      "word_count": 7, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["V", "W", "AW"] },
  { "id": "s_054", "item_type": "sentence", "text": "Tell me what you did at the weekend.",                      "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "linking", "rhythm"],             "target_phonemes": ["T", "W", "K"] },
  { "id": "s_055", "item_type": "sentence", "text": "I'm looking forward to seeing you again.",                  "word_count": 7, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["L", "F", "Y"] },
  { "id": "s_056", "item_type": "sentence", "text": "She called me just before I left.",                         "word_count": 7, "cefr_level": "A2", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["SH", "K", "B"] },
  { "id": "s_057", "item_type": "sentence", "text": "They've decided to move to the countryside.",               "word_count": 7, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["DH", "S", "K"] },
  { "id": "s_058", "item_type": "sentence", "text": "I had to wait a long time.",                                "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "rhythm"],                                     "target_phonemes": ["HH", "W", "T"] },
  { "id": "s_059", "item_type": "sentence", "text": "Can you give me a hand please?",                            "word_count": 7, "cefr_level": "A2", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["K", "G", "HH"] },
  { "id": "s_060", "item_type": "sentence", "text": "We always have lunch at the same place.",                   "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["W", "L", "S"] },
  { "id": "s_061", "item_type": "sentence", "text": "The children love playing in the park.",                    "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["CH", "L", "P"] },
  { "id": "s_062", "item_type": "sentence", "text": "He gave her a book for her birthday.",                      "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["G", "B", "TH"] },
  { "id": "s_063", "item_type": "sentence", "text": "I always drink tea in the morning.",                        "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["L", "T", "M"] },
  { "id": "s_064", "item_type": "sentence", "text": "She works in a hospital near the city.",                    "word_count": 8, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["SH", "HH", "S"] },
  { "id": "s_065", "item_type": "sentence", "text": "We took the bus to the airport.",                           "word_count": 7, "cefr_level": "A1", "difficulty": "easy",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["T", "B", "P"] },

  { "id": "s_066", "item_type": "sentence", "text": "I need to find out what time the meeting starts.",                "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "reductions", "rhythm"],  "target_phonemes": ["F", "T", "M"] },
  { "id": "s_067", "item_type": "sentence", "text": "She told me she would be home by eight o'clock.",                  "word_count": 11, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["SH", "T", "B"] },
  { "id": "s_068", "item_type": "sentence", "text": "We should have called them before we left the house.",             "word_count": 11, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["SH", "K", "L"] },
  { "id": "s_069", "item_type": "sentence", "text": "He's been thinking about changing jobs for quite some time.",      "word_count": 11, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["TH", "CH", "JH"] },
  { "id": "s_070", "item_type": "sentence", "text": "I don't think she's going to come to the party.",                  "word_count": 11, "cefr_level": "A2", "difficulty": "medium", "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["TH", "G", "P"] },
  { "id": "s_071", "item_type": "sentence", "text": "Could you tell me how to get to the station?",                     "word_count": 11, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["K", "HH", "S"] },
  { "id": "s_072", "item_type": "sentence", "text": "They've been living in the same house for ten years.",             "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["L", "HH", "Y"] },
  { "id": "s_073", "item_type": "sentence", "text": "I was going to phone you but I forgot.",                            "word_count": 10, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "rhythm"],                           "target_phonemes": ["G", "F", "Y"] },
  { "id": "s_074", "item_type": "sentence", "text": "She asked him to turn off the light before leaving.",               "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["SH", "T", "L"] },
  { "id": "s_075", "item_type": "sentence", "text": "We're not sure whether we'll be able to come tomorrow.",            "word_count": 11, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["W", "DH", "B"] },
  { "id": "s_076", "item_type": "sentence", "text": "The children were playing in the garden when it started raining.",  "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["CH", "P", "G"] },
  { "id": "s_077", "item_type": "sentence", "text": "I'd like to know more about the course before I decide.",           "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["L", "K", "B"] },
  { "id": "s_078", "item_type": "sentence", "text": "He said he'd help me with the report this afternoon.",              "word_count": 11, "cefr_level": "A2", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["HH", "R", "F"] },
  { "id": "s_079", "item_type": "sentence", "text": "We didn't have time to finish everything we wanted to do.",         "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["D", "F", "W"] },
  { "id": "s_080", "item_type": "sentence", "text": "Have you ever been to that new restaurant on the corner?",          "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["V", "R", "K"] },
  { "id": "s_081", "item_type": "sentence", "text": "I'm sure you'll find what you're looking for at the market.",       "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["SH", "F", "M"] },
  { "id": "s_082", "item_type": "sentence", "text": "They asked us if we could give them a lift home.",                  "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["DH", "K", "L"] },
  { "id": "s_083", "item_type": "sentence", "text": "She's been waiting for the bus for over twenty minutes.",           "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["W", "B", "T"] },
  { "id": "s_084", "item_type": "sentence", "text": "It's going to take a few days to get used to it.",                  "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["G", "T", "Y"] },
  { "id": "s_085", "item_type": "sentence", "text": "I haven't decided yet whether to take the job or not.",             "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["V", "DH", "JH"] },
  { "id": "s_086", "item_type": "sentence", "text": "We had to leave early because we had another appointment.",         "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["L", "K", "P"] },
  { "id": "s_087", "item_type": "sentence", "text": "Why don't you ask him if he wants to come along?",                  "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["W", "HH", "K"] },
  { "id": "s_088", "item_type": "sentence", "text": "I really wish I had more time to spend with my family.",            "word_count": 13, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["W", "M", "F"] },
  { "id": "s_089", "item_type": "sentence", "text": "They moved into the new flat just before Christmas last year.",     "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["M", "F", "K"] },
  { "id": "s_090", "item_type": "sentence", "text": "Could you let me know when you've finished reading the book?",       "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["K", "L", "R"] },
  { "id": "s_091", "item_type": "sentence", "text": "She kept asking me the same question over and over again.",         "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                "target_phonemes": ["SH", "K", "S"] },
  { "id": "s_092", "item_type": "sentence", "text": "I think we should sit down and talk about it together.",            "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["TH", "T", "G"] },
  { "id": "s_093", "item_type": "sentence", "text": "He hasn't been feeling well for the last couple of days.",          "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["HH", "F", "K"] },
  { "id": "s_094", "item_type": "sentence", "text": "We were just about to leave when the phone started ringing.",       "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["W", "L", "F"] },
  { "id": "s_095", "item_type": "sentence", "text": "It's important to drink plenty of water during hot weather.",       "word_count": 11, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["P", "W", "DH"] },
  { "id": "s_096", "item_type": "sentence", "text": "I would have called you earlier but I couldn't find my phone.",     "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],  "target_phonemes": ["W", "K", "F"] },
  { "id": "s_097", "item_type": "sentence", "text": "She's been studying English for nearly five years now.",            "word_count": 10, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["S", "NG", "F"] },
  { "id": "s_098", "item_type": "sentence", "text": "If you have a moment later, could you check these documents?",      "word_count": 12, "cefr_level": "B2", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["F", "M", "CH"] },
  { "id": "s_099", "item_type": "sentence", "text": "He told me a story about something funny that happened today.",     "word_count": 12, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["T", "TH", "F"] },
  { "id": "s_100", "item_type": "sentence", "text": "There's nothing in the fridge so I'll go shopping this afternoon.", "word_count": 12, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                "target_phonemes": ["TH", "SH", "F"] },

  { "id": "s_101", "item_type": "sentence_group", "text": "I went to the shop yesterday. They didn't have what I needed. I'll try somewhere else tomorrow.",                     "word_count": 18, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["W", "SH", "T"] },
  { "id": "s_102", "item_type": "sentence_group", "text": "She lives in a small flat near the park. It's a nice place. The neighbours are very friendly.",                       "word_count": 19, "cefr_level": "A2", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["L", "F", "P"] },
  { "id": "s_103", "item_type": "sentence_group", "text": "We're planning a trip next month. We haven't booked the flights yet. There's still plenty of time.",                  "word_count": 19, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["P", "F", "T"] },
  { "id": "s_104", "item_type": "sentence_group", "text": "The film was really good. I didn't expect it to be so long. I almost fell asleep at the end.",                        "word_count": 22, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["F", "L", "S"] },
  { "id": "s_105", "item_type": "sentence_group", "text": "He's been working very hard lately. He needs a break. Maybe we should plan a holiday together.",                      "word_count": 19, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["W", "B", "HH"] },
  { "id": "s_106", "item_type": "sentence_group", "text": "I love reading in the evenings. It helps me relax. I usually finish a book every couple of weeks.",                   "word_count": 21, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["L", "R", "F"] },
  { "id": "s_107", "item_type": "sentence_group", "text": "We met at a party last summer. We've been good friends ever since. We talk almost every day.",                        "word_count": 20, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["M", "S", "F"] },
  { "id": "s_108", "item_type": "sentence_group", "text": "The weather has been terrible this week. It's rained nearly every day. I hope it gets better soon.",                  "word_count": 21, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["W", "DH", "R"] },
  { "id": "s_109", "item_type": "sentence_group", "text": "She's just started a new job. She seems to be enjoying it. Her colleagues are very welcoming.",                       "word_count": 19, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["SH", "JH", "K"] },
  { "id": "s_110", "item_type": "sentence_group", "text": "I forgot to bring my umbrella. Now I'm completely soaked. I should have checked the forecast.",                       "word_count": 18, "cefr_level": "B1", "difficulty": "hard",   "features": ["reductions", "weak_forms", "linking", "rhythm"],            "target_phonemes": ["F", "M", "K"] },
  { "id": "s_111", "item_type": "sentence_group", "text": "We had dinner at a new restaurant. The food was excellent. We'll definitely go back next week.",                      "word_count": 19, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["D", "F", "W"] },
  { "id": "s_112", "item_type": "sentence_group", "text": "He's learning to play the guitar. He practises every evening after work. He's getting much better.",                  "word_count": 20, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["L", "P", "G"] },
  { "id": "s_113", "item_type": "sentence_group", "text": "I usually walk to work. It takes about twenty minutes. The exercise helps me wake up properly.",                      "word_count": 20, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["W", "T", "K"] },
  { "id": "s_114", "item_type": "sentence_group", "text": "The children have gone to bed. The house is finally quiet. I can have a cup of tea in peace.",                        "word_count": 22, "cefr_level": "B1", "difficulty": "medium", "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["CH", "HH", "K"] },
  { "id": "s_115", "item_type": "sentence_group", "text": "She wanted to surprise her mother. She made a special cake. Her mother was really touched.",                          "word_count": 18, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["SH", "M", "K"] },
  { "id": "s_116", "item_type": "sentence_group", "text": "We've lived here for ten years. We know everyone in the street. It feels like a real community.",                     "word_count": 19, "cefr_level": "B1", "difficulty": "hard",   "features": ["linking", "weak_forms", "rhythm"],                          "target_phonemes": ["V", "Y", "S"] },
  { "id": "s_117", "item_type": "sentence_group", "text": "I'm thinking about taking a course. I want to learn something new. There are several options online.",                "word_count": 19, "cefr_level": "B2", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["TH", "K", "L"] },
  { "id": "s_118", "item_type": "sentence_group", "text": "The bus was late this morning. I had to wait nearly half an hour. I almost missed my appointment.",                   "word_count": 22, "cefr_level": "B1", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["B", "M", "P"] },
  { "id": "s_119", "item_type": "sentence_group", "text": "He didn't say much during dinner. I could tell he was worried. I asked him about it later.",                          "word_count": 20, "cefr_level": "B1", "difficulty": "medium", "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["D", "S", "W"] },
  { "id": "s_120", "item_type": "sentence_group", "text": "We watched a documentary about whales last night. It was fascinating. I had no idea they were so intelligent.",       "word_count": 20, "cefr_level": "B2", "difficulty": "hard",   "features": ["weak_forms", "linking", "rhythm"],                          "target_phonemes": ["W", "F", "DH"] }
]
